# ═══════════════════════════════════════════════════════════════════════════
# FLG Jornada System — Variáveis de Ambiente
# Copie para .env e preencha. NUNCA commite o .env com chaves reais no git.
# ═══════════════════════════════════════════════════════════════════════════

# ─── Claude / Anthropic ──────────────────────────────────────────────────────
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-COLOQUE-SUA-CHAVE-AQUI

# ─── Supabase — Backend (service role, acesso total) ─────────────────────────
# Settings → API → Project URL
SUPABASE_URL=https://XXXXX.supabase.co

# Settings → API → Secret key (sb_secret_...)
SUPABASE_KEY=sb_secret_...

# Settings → Database → Connection string → Session mode (porta 5432)
# Formato: postgresql+psycopg://postgres.XXXXX:SENHA@aws-0-us-east-1.pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=postgresql+psycopg://postgres.XXXXX:SENHA@HOST:5432/postgres

# ─── ClickUp ─────────────────────────────────────────────────────────────────
# ClickUp → Settings → Apps → API Token (opcional)
CLICKUP_API_TOKEN=

# ─── Frontend (variáveis públicas — podem ser expostas no browser) ────────────
# Settings → API → Project URL
VITE_SUPABASE_URL=https://XXXXX.supabase.co

# Settings → API → Publishable key (sb_publishable_...)
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# URL base do backend
VITE_API_URL=https://docs.foundersledgrowth.online/api
