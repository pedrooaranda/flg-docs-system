# ═══════════════════════════════════════════════════════════════════════════
# FLG Jornada System — Variáveis de Ambiente
# Copie para .env e preencha. NUNCA commite o .env com chaves reais no git.
# ═══════════════════════════════════════════════════════════════════════════

# ─── Claude / Anthropic ──────────────────────────────────────────────────────
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-COLOQUE-SUA-CHAVE-AQUI

# ─── Supabase — Backend (service role, acesso total) ─────────────────────────
# Settings → API → Project URL
SUPABASE_URL=https://XXXXX.supabase.co

# Settings → API → service_role key (NUNCA exponha no frontend)
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Settings → Database → Connection string → "Session mode" (porta 5432)
# Formato: postgresql+psycopg://postgres.XXXXX:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=postgresql+psycopg://postgres.XXXXX:PASSWORD@HOST:5432/postgres

# Settings → API → JWT Secret (para validar tokens no FastAPI)
SUPABASE_JWT_SECRET=COLOQUE-O-JWT-SECRET-AQUI

# ─── ClickUp ─────────────────────────────────────────────────────────────────
# Obtenha em: ClickUp → Settings → Apps → API Token
CLICKUP_API_TOKEN=pk_COLOQUE-SEU-TOKEN-AQUI

# ─── Frontend (variáveis públicas — podem ser expostas no browser) ────────────
# Settings → API → Project URL (igual ao SUPABASE_URL)
VITE_SUPABASE_URL=https://XXXXX.supabase.co

# Settings → API → anon key (pública, usada pelo React)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL base do backend (com /api — Traefik faz o strip)
VITE_API_URL=https://docs.foundersledgrowth.online/api

# ─── Scripts originais (gerador de templates HTML) ───────────────────────────
# Obtenha em: https://console.anthropic.com/ (mesmo key acima)
# ANTHROPIC_API_KEY já declarado acima
